# ============================================
# DataQuery AI 环境变量
# 复制此文件为 .env： cp .env.example .env
# ============================================

# --- 编码（Windows 必须，防止中文乱码）---
PYTHONIOENCODING=utf-8

# --- LLM 配置（必填）---
# 任何兼容 OpenAI API 的服务均可，切换 base_url 即可
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4.1
LLM_BASE_URL=https://api.openai.com/v1
# 国内可用代理示例：
# LLM_BASE_URL=https://api.openai-proxy.org/v1

# --- 数据库（与 docker compose 默认密码一致，无需修改）---
DB_META_USER=atguigu
DB_META_PASSWORD=Atguigu.123
DB_DW_USER=atguigu
DB_DW_PASSWORD=Atguigu.123
